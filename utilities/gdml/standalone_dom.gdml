    <rotation name="rot_9" x="-30.3" y="71.4" z="0.0" unit="deg"/>
    <rotation name="rot_10" x="-136.96" y="38.12" z="0.0" unit="deg"/>
    <rotation name="rot_11" x="-118.72" y="71.67" z="0.0" unit="deg"/>
    <rotation name="rot_12" x="-136.95" y="-38.12" z="0.0" unit="deg"/>
    <rotation name="rot_13" x="-164.0" y="0.0" z="0.0" unit="deg"/>
    <rotation name="rot_14" x="-90.0" y="-57.49" z="0.0" unit="deg"/>
    <rotation name="rot_15" x="-118.74" y="-71.66" z="0.0" unit="deg"/>
    <rotation name="rot_16" x="-43.04" y="-38.12" z="0.0" unit="deg"/>
    <rotation name="rot_17" x="-61.26" y="-71.67" z="0.0" unit="deg"/>
    <rotation name="rot_18" x="-43.05" y="38.12" z="0.0" unit="deg"/>
    <rotation name="rot_19" x="57.5" y="0.0" z="0.0" unit="deg"/>
    <rotation name="rot_20" x="89.99" y="74.0" z="0.0" unit="deg"/>
    <rotation name="rot_21" x="65.05" y="53.64" z="0.0" unit="deg"/>
    <rotation name="rot_22" x="146.33" y="60.0" z="0.0" unit="deg"/>
    <rotation name="rot_23" x="114.95" y="53.65" z="0.0" unit="deg"/>
    <rotation name="rot_24" x="146.36" y="-60.0" z="0.0" unit="deg"/>
    <rotation name="rot_25" x="147.5" y="0.0" z="0.0" unit="deg"/>
    <rotation name="rot_26" x="89.99" y="-74.0" z="0.0" unit="deg"/>
    <rotation name="rot_27" x="114.95" y="-53.64" z="0.0" unit="deg"/>
    <rotation name="rot_28" x="33.67" y="-60.0" z="0.0" unit="deg"/>
    <rotation name="rot_29" x="65.05" y="-53.65" z="0.0" unit="deg"/>
    <rotation name="rot_30" x="33.64" y="60.0" z="0.0" unit="deg"/>

    <!-- Position for composing the PMT solid -->
    <position name="FaceOnBody" z="60" unit="mm"/>
  </define>

  <!--
  ================================================================================================
  MATERIALS
  ================================================================================================
  -->
  <materials>
    <material name="Vacuum" Z="1.0" N="1.008">
      <D value="1.e-25" unit="g/cm3"/>
    </material>
    <material name="PMT_Material" Z="14.0" N="28.0855">
      <D value="2.33" unit="g/cm3"/>
    </material>
  </materials>

  <!--
  ================================================================================================
  SOLIDS
  The PMT solid is now a composite of two tubes to make the orientation clearer.
  - PMTBodyTube: The narrower, longer back section (the "body").
  - PMTFaceTube: The wider, shorter front section (the "face").
  ================================================================================================
  -->
  <solids>
    <box name="WorldBox" x="1000" y="1000" z="1000" lunit="mm"/>
    
    <!-- Define the two parts of the PMT -->
    <tube name="PMTBodyTube" rmin="0" rmax="25" z="100" startphi="0" deltaphi="360" aunit="deg" lunit="mm"/>
    <tube name="PMTFaceTube" rmin="0" rmax="35" z="20" startphi="0" deltaphi="360" aunit="deg" lunit="mm"/>

    <!-- Combine the two parts into a single solid. The Face is placed at the front of the Body. -->
    <union name="PMTsolid">
      <first ref="PMTBodyTube"/>
      <second ref="PMTFaceTube"/>
      <positionref ref="FaceOnBody"/>
    </union>
  </solids>

  <!--
  ================================================================================================
  STRUCTURE
  ================================================================================================
  -->
  <structure>
    <volume name="logicPMT">
      <materialref ref="PMT_Material"/>
      <solidref ref="PMTsolid"/>
    </volume>

    <volume name="logicWorld">
      <materialref ref="Vacuum"/>
      <solidref ref="WorldBox"/>
      <!-- Place all 31 PMTs inside the World Volume -->
      <physvol name="physPMT_0"><volumeref ref="logicPMT"/><positionref ref="pos_0"/><rotationref ref="rot_0"/></physvol>
      <physvol name="physPMT_1"><volumeref ref="logicPMT"/><positionref ref="pos_1"/><rotationref ref="rot_1"/></physvol>
      <physvol name="physPMT_2"><volumeref ref="logicPMT"/><positionref ref="pos_2"/><rotationref ref="rot_2"/></physvol>
      <physvol name="physPMT_3"><volumeref ref="logicPMT"/><positionref ref="pos_3"/><rotationref ref="rot_3"/></physvol>
      <physvol name="physPMT_4"><volumeref ref="logicPMT"/><positionref ref="pos_4"/><rotationref ref="rot_4"/></physvol>
      <physvol name="physPMT_5"><volumeref ref="logicPMT"/><positionref ref="pos_5"/><rotationref ref="rot_5"/></physvol>
      <physvol name="physPMT_6"><volumeref ref="logicPMT"/><positionref ref="pos_6"/><rotationref ref="rot_6"/></physvol>
      <physvol name="physPMT_7"><volumeref ref="logicPMT"/><positionref ref="pos_7"/><rotationref ref="rot_7"/></physvol>
      <physvol name="physPMT_8"><volumeref ref="logicPMT"/><positionref ref="pos_8"/><rotationref ref="rot_8"/></physvol>
      <physvol name="physPMT_9"><volumeref ref="logicPMT"/><positionref ref="pos_9"/><rotationref ref="rot_9"/></physvol>
      <physvol name="physPMT_10"><volumeref ref="logicPMT"/><positionref ref="pos_10"/><rotationref ref="rot_10"/></physvol>
      <physvol name="physPMT_11"><volumeref ref="logicPMT"/><positionref ref="pos_11"/><rotationref ref="rot_11"/></physvol>
      <physvol name="physPMT_12"><volumeref ref="logicPMT"/><positionref ref="pos_12"/><rotationref ref="rot_12"/></physvol>
      <physvol name="physPMT_13"><volumeref ref="logicPMT"/><positionref ref="pos_13"/><rotationref ref="rot_13"/></physvol>
      <physvol name="physPMT_14"><volumeref ref="logicPMT"/><positionref ref="pos_14"/><rotationref ref="rot_14"/></physvol>
      <physvol name="physPMT_15"><volumeref ref="logicPMT"/><positionref ref="pos_15"/><rotationref ref="rot_15"/></physvol>
      <physvol name="physPMT_16"><volumeref ref="logicPMT"/><positionref ref="pos_16"/><rotationref ref="rot_16"/></physvol>
      <physvol name="physPMT_17"><volumeref ref="logicPMT"/><positionref ref="pos_17"/><rotationref ref="rot_17"/></physvol>
      <physvol name="physPMT_18"><volumeref ref="logicPMT"/><positionref ref="pos_18"/><rotationref ref="rot_18"/></physvol>
      <physvol name="physPMT_19"><volumeref ref="logicPMT"/><positionref ref="pos_19"/><rotationref ref="rot_19"/></physvol>
      <physvol name="physPMT_20"><volumeref ref="logicPMT"/><positionref ref="pos_20"/><rotationref ref="rot_20"/></physvol>
      <physvol name="physPMT_21"><volumeref ref="logicPMT"/><positionref ref="pos_21"/><rotationref ref="rot_21"/></physvol>
      <physvol name="physPMT_22"><volumeref ref="logicPMT"/><positionref ref="pos_22"/><rotationref ref="rot_22"/></physvol>
      <physvol name="physPMT_23"><volumeref ref="logicPMT"/><positionref ref="pos_23"/><rotationref ref="rot_23"/></physvol>
      <physvol name="physPMT_24"><volumeref ref="logicPMT"/><positionref ref="pos_24"/><rotationref ref="rot_24"/></physvol>
      <physvol name="physPMT_25"><volumeref ref="logicPMT"/><positionref ref="pos_25"/><rotationref ref="rot_25"/></physvol>
      <physvol name="physPMT_26"><volumeref ref="logicPMT"/><positionref ref="pos_26"/><rotationref ref="rot_26"/></physvol>
      <physvol name="physPMT_27"><volumeref ref="logicPMT"/><positionref ref="pos_27"/><rotationref ref="rot_27"/></physvol>
      <physvol name="physPMT_28"><volumeref ref="logicPMT"/><positionref ref="pos_28"/><rotationref ref="rot_28"/></physvol>
      <physvol name="physPMT_29"><volumeref ref="logicPMT"/><positionref ref="pos_29"/><rotationref ref="rot_29"/></physvol>
      <physvol name="physPMT_30"><volumeref ref="logicPMT"/><positionref ref="pos_30"/><rotationref ref="rot_30"/></physvol>    
    </volume>
  </structure>

  <!--
  ================================================================================================
  SETUP
  ================================================================================================
  -->
  <setup name="Default" version="1.0">
    <world ref="logicWorld"/>
  </setup>

</gdml>

