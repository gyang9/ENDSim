    <position name="pos_25" x="-0.00758869613" y="106.365682" z="-166.975496" unit="mm"/>
    <position name="pos_26" x="190.309996" y="54.5766634" z="-0.0357977582" unit="mm"/>
    <position name="pos_27" x="144.60122658" y="106.36568243" z="-83.49431976" unit="mm"/>
    <position name="pos_28" x="95.18599956" y="54.57666342" z="164.79539189" unit="mm"/>
    <position name="pos_29" x="144.60881528" y="106.36568243" z="83.48117575" unit="mm"/>
    <position name="pos_30" x="-95.12399602" y="54.57666342" z="164.83118965" unit="mm"/>

    <!-- PMT Rotations (Using user-verified values and derived logic) -->
    <rotation name="rot_0" x="-90.0" y="0.0" z="0.0" unit="deg"/>
    <rotation name="rot_1" x="-56.79" y="0.0" z="0.0" unit="deg"/>
    <rotation name="rot_2" x="-74.09" y="29.2" z="0.0" unit="deg"/>
    <rotation name="rot_3" x="-106.18" y="29.2" z="0.0" unit="deg"/>
    <rotation name="rot_4" x="-146.79" y="0.0" z="0.0" unit="deg"/>
    <rotation name="rot_5" x="-106.18" y="-29.54" z="0.0" unit="deg"/>
    <rotation name="rot_6" x="-74.09" y="-29.54" z="0.0" unit="deg"/>
    <rotation name="rot_7" x="-16.0" y="0.0" z="0.0" unit="deg"/>
