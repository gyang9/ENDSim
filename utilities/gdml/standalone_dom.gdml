<?xml version="1.0" encoding="UTF-8"?>
<gdml xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://service-spi.web.cern.ch/service-spi/app/releases/GDML/schema/gdml.xsd">

  <!--
  ================================================================================================
  DEFINES
  This file contains all 31 PMTs. The rotations for the first 10 PMTs have been set to the
  user-verified values. The rotations for the remaining PMTs have been calculated based on the
  pattern derived from those correct values.
  ================================================================================================
  -->
  <define>
