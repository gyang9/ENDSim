    <position name="pos_15" x="164.7950254" y="-54.57666342" z="-95.16611935" unit="mm"/>
    <position name="pos_16" x="83.4789564" y="-106.3480569" z="144.60990444" unit="mm"/>
    <position name="pos_17" x="164.81378963" y="-54.57666342" z="95.13361874" unit="mm"/>
